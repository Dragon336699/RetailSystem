@using RetailSystem.SharedLibrary.Contracts.Users;
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Register";
}
@model RegisterCustomerRequest

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body, html {
        height: 100%;
        font-family: 'Nunito', sans-serif;
        background: #f0f2fa;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .register-wrapper {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(90, 94, 244, 0.12);
        width: 420px;
        padding: 44px 40px 40px;
    }

    .register-title {
        font-size: 28px;
        font-weight: 900;
        color: #1a1d2e;
        margin-bottom: 32px;
        letter-spacing: -0.5px;
    }

    .field-group {
        margin-bottom: 18px;
    }

    .field-label {
        display: block;
        font-size: 13px;
        font-weight: 700;
        color: #4a4d65;
        margin-bottom: 7px;
        letter-spacing: 0.1px;
    }

        .field-label .validation-error {
            color: #e05260;
            font-weight: 600;
            font-size: 12px;
            margin-left: 6px;
        }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        left: 14px;
        color: #9496b0;
        display: flex;
        align-items: center;
        pointer-events: none;
    }

    .input-wrapper input {
        width: 100%;
        padding: 12px 14px 12px 40px;
        border: 1.5px solid #e2e4f0;
        border-radius: 10px;
        font-family: 'Nunito', sans-serif;
        font-size: 14px;
        font-weight: 600;
        color: #1a1d2e;
        background: #fafbff;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
    }

        .input-wrapper input::placeholder {
            color: #b0b3cc;
            font-weight: 500;
        }

        .input-wrapper input:focus {
            border-color: #5b5ef4;
            box-shadow: 0 0 0 3px rgba(91, 94, 244, 0.12);
            background: #fff;
        }

        .input-wrapper input.input-error {
            border-color: #e05260;
            box-shadow: 0 0 0 3px rgba(224, 82, 96, 0.10);
        }

    .field-validation-error {
        color: #e05260;
        font-size: 12px;
        font-weight: 600;
        margin-top: 5px;
        display: block;
    }

    .validation-summary-errors ul {
        list-style: none;
        padding: 0;
    }

    .validation-summary-errors {
        background: #fff0f1;
        border: 1px solid #f5c6cb;
        border-radius: 10px;
        padding: 10px 14px;
        margin-bottom: 18px;
        color: #e05260;
        font-size: 13px;
        font-weight: 600;
    }

    .btn-register {
        width: 100%;
        padding: 13px;
        background: #5b5ef4;
        color: #fff;
        border: none;
        border-radius: 10px;
        font-family: 'Nunito', sans-serif;
        font-size: 15px;
        font-weight: 800;
        letter-spacing: 0.2px;
        cursor: pointer;
        margin-top: 8px;
        transition: background 0.2s, transform 0.1s, box-shadow 0.2s;
        box-shadow: 0 4px 16px rgba(91, 94, 244, 0.25);
    }

        .btn-register:hover {
            background: #4749e8;
            box-shadow: 0 6px 22px rgba(91, 94, 244, 0.35);
            transform: translateY(-1px);
        }

        .btn-register:active {
            transform: translateY(0);
            box-shadow: 0 2px 10px rgba(91, 94, 244, 0.2);
        }

    #error {
        color: #e05260;
        font-size: 13px;
        font-weight: 600;
        margin-top: 10px;
        text-align: center;
    }

    .login-link {
        text-align: center;
        margin-top: 20px;
        font-size: 13px;
        color: #9496b0;
        font-weight: 600;
    }

        .login-link a {
            color: #5b5ef4;
            text-decoration: none;
            font-weight: 700;
        }

            .login-link a:hover {
                text-decoration: underline;
            }
</style>

<div class="register-wrapper">
    <h2 class="register-title">Register account</h2>

    <form id="registerForm" asp-action="RegisterUser" asp-controller="Auth" method="post">

        <div asp-validation-summary="All" class="text-danger"></div>

        <!-- Username -->
        <div class="field-group">
            <label class="field-label" for="userName">
                User Name
            </label>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </span>
                <input asp-for="UserName" id="userName" placeholder="Ex: dragon3366" />
            </div>
            <span asp-validation-for="UserName" class="field-validation-error"></span>
        </div>

        <!-- Full Name -->
        <div class="field-group">
            <label class="field-label" for="fullName">
                Full Name
            </label>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                </span>
                <input asp-for="FullName" id="fullName" placeholder="Ex: Bảo Long" />
            </div>
            <span asp-validation-for="FullName" class="field-validation-error"></span>
        </div>

        <!-- Password -->
        <div class="field-group">
            <label class="field-label" for="password">
                Password
            </label>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                </span>
                <input type="password" asp-for="Password" id="password" placeholder="Ex: Test123123" />
            </div>
            <span asp-validation-for="Password" class="field-validation-error"></span>
        </div>

        <!-- Confirm Password -->
        <div class="field-group">
            <label class="field-label" for="confirmPassword">
                Confirm Password
            </label>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                    </svg>
                </span>
                <input type="password" asp-for="ConfirmPassword" id="confirmPassword" placeholder="Ex: Test123123" />
            </div>
            <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
        </div>

        <button type="submit" class="btn-register">Register</button>

        <div id="error" class="text-danger mt-2 small"></div>
    </form>
</div>
