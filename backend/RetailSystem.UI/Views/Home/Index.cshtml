<div class="row g-3 mb-4">
    @foreach (var product in Model.FeatureProducts)
    {
        <div class="col-6 col-md-3 style=" cursor: pointer"">
            <a href="@Url.Action("Detail", "Product", new { id = product.Id })"
               class="text-decoration-none text-dark d-block h-100"
               style="cursor: pointer;">

                <div class="card h-100 border-0 shadow-sm">
                    <img src="@product.ProductImages.FirstOrDefault(pi => pi.IsThumbnail).ImageUrl"
                         alt="@product.ProductName"
                         class="card-img-top object-fit-cover"
                         style="aspect-ratio: 1/1;" />

                    <div class="card-body d-flex flex-column p-2">
                        <h6 class="card-title fw-bold mb-1">@product.ProductName</h6>

                        @if (!string.IsNullOrEmpty(product.Description))
                        {
                            <p class="card-text text-muted small mb-1"
                               style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @product.Description
                            </p>
                        }

                        <p class="fw-semibold text-primary mt-auto mb-0">
                            @product.Price.ToString("C")
                        </p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<div class="text-center mb-4">
    <a href="/products" class="btn btn-dark px-4">View All Products</a>
</div>
