@using RetailSystem.UI.Models.Home;
@model HomeViewModel
@{
    ViewData["Title"] = "Retail System";
}

<div class="featured-grid mb-5">
    @foreach (var product in Model.FeatureProducts)
    {
        <a href="@Url.Action("Detail", "Product", new { id = product.Id })" class="fcard-link">
            <div class="fcard">
                <div class="fcard-img-wrapper">
                    <img src="@product.ProductImages.FirstOrDefault(pi => pi.IsThumbnail).ImageUrl"
                         alt="@product.ProductName" />
                </div>
                <div class="fcard-body">
                    <h6 class="fcard-name">@product.ProductName</h6>
                    @if (!string.IsNullOrEmpty(product.Description))
                    {
                        <p class="fcard-desc">@product.Description</p>
                    }
                    <p class="fcard-price">@product.Price.ToString("C")</p>
                </div>
            </div>
        </a>
    }
</div>

<div class="text-center mb-5">
    <a href="/products" class="view-all-btn">View All Products</a>
</div>

<style>
    /* ── Grid ── */
    .featured-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        align-items: stretch; /* quan trọng */
    }

    @@media (max-width: 992px) {
        .featured-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 640px) {
        .featured-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* ── Card ── */
    .fcard-link {
        text-decoration: none;
        color: inherit;
        display: block;
        height: 100%;
    }

    .fcard {
        height: 100%; /* ép full height theo grid cell */
        display: flex;
        flex-direction: column;
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        /* layered shadow: tight inner + soft outer — makes white-bg images pop */
        box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.06), 0 2px 8px rgba(0, 0, 0, 0.07), 0 8px 28px rgba(0, 0, 0, 0.09);
        transition: transform 0.22s ease, box-shadow 0.22s ease;
    }

        .fcard:hover {
            transform: translateY(-6px);
            box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.07), 0 6px 20px rgba(0, 0, 0, 0.10), 0 20px 48px rgba(0, 0, 0, 0.13);
        }

    /* ── Image area ── */
    .fcard-img-wrapper {
        background: #f8f8f8;
        padding: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .fcard-img-wrapper img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: contain; /* contain keeps full shoe visible on white bg */
            display: block;
            transition: transform 0.32s ease;
        }

    .fcard:hover .fcard-img-wrapper img {
        transform: scale(1.06);
    }

    /* ── Body ── */
    .fcard-body {
        padding: 14px 16px 18px;
        border-top: 1px solid #f0f0f0;
        flex: 1; /* đẩy phần body giãn đều */
        display: flex;
        flex-direction: column;
    }

    .fcard-name {
        font-size: 14px;
        font-weight: 700;
        color: #111;
        margin: 0 0 5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        letter-spacing: -0.01em;
    }

    .fcard-desc {
        font-size: 12px;
        color: #aaa;
        margin: 0 0 10px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.5;
    }

    .fcard-price {
        font-size: 15px;
        font-weight: 700;
        color: #1a56db;
        margin: 0;
        letter-spacing: -0.01em;
    }

    /* ── View All button ── */
    .view-all-btn {
        display: inline-block;
        padding: 12px 36px;
        background: #111;
        color: #fff;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        letter-spacing: 0.02em;
        transition: background 0.18s, transform 0.18s, box-shadow 0.18s;
        box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    }

        .view-all-btn:hover {
            background: #333;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.20);
            color: #fff;
        }
</style>
