@using RetailSystem.UI.Models.Product;
@model ProductViewModel

@{
    var product = Model.Product;
    var mainImage = product.ProductImages.FirstOrDefault()?.ImageUrl ?? "";
}

<div class="container py-4">
    <div class="row g-4">

        <div class="col-12 col-md-6">
            <div class="border rounded overflow-hidden mb-2" style="aspect-ratio: 1/1;">
                <img id="mainImage"
                     src="@mainImage"
                     alt="@product.ProductName"
                     class="w-100 h-100 object-fit-cover" />
            </div>

            @if (product.ProductImages.Count > 1)
            {
                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var img in product.ProductImages)
                    {
                        <div class="border rounded overflow-hidden thumbnail-item"
                             style="width: 72px; height: 72px; cursor: pointer;"
                             onclick="selectImage(this, '@img.ImageUrl')">
                            <img src="@img.ImageUrl"
                                 alt="@product.ProductName"
                                 class="w-100 h-100 object-fit-cover" />
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-12 col-md-6 d-flex flex-column gap-3">

            <div>
                <h1 class="fs-3 fw-bold mb-1">@product.ProductName</h1>
                <div class="d-flex align-items-center gap-2">
                    <div class="text-warning">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor((double)product.RatingAverage))
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                            else if (i - product.RatingAverage < 1 && i - product.RatingAverage > 0)
                            {
                                <i class="bi bi-star-half"></i>
                            }
                            else
                            {
                                <i class="bi bi-star"></i>
                            }
                        }
                    </div>
                    <span class="text-muted small">(@product.RatingAverage.ToString("0.0"))</span>
                </div>
            </div>

            <div class="fs-4 fw-semibold text-primary">
                @product.Price.ToString("C")
            </div>

            @if (product.Categories?.Any() == true)
            {
                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var cat in product.Categories)
                    {
                        <span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill px-3 py-1">
                            @cat.CategoryName
                        </span>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(product.Description))
            {
                <p class="text-muted mb-0">@product.Description</p>
            }

            <hr class="my-1" />

            <div>
                <p class="fw-semibold mb-2">Select Size</p>
                <div class="d-flex gap-2 flex-wrap" id="sizeSelector">

                    @foreach (var size in Model.Sizes)
                    {
                        var matchedSize = product.ProductVariants.FirstOrDefault(pv => pv.SizeId == size.Id);
                        bool available = false;

                        if (matchedSize != null && matchedSize?.StockQuantity > 0)
                        {
                            available = true;
                        }

                        <button type="button"
                                class="btn @(available ? "btn-outline-dark" : "btn-outline-secondary") size-btn"
                                style="min-width: 56px; @(!available ? "opacity: 0.4; text-decoration: line-through;" : "")"
                                data-size-id="@size.Id"
                                @(!available ? "disabled" : "")
                                onclick="selectSize(this)">
                            @size.SizeNumber
                        </button>
                    }
                </div>
                <p id="sizeError" class="text-danger small mt-1 d-none">Please select a size.</p>
            </div>
            @if (product.Description != null)
            {
                <div>
                    <p class="fw-semibold mb-2">Description</p>
                    <p>@product?.Description</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let selectedSizeId = null;

        function selectImage(el, url) {
            document.getElementById('mainImage').src = url;
            document.querySelectorAll('.thumbnail-item').forEach(t => t.classList.remove('border-dark', 'border-2'));
            el.classList.add('border-dark', 'border-2');
        }

        function selectSize(el) {
            if (el.disabled) return;
            document.querySelectorAll('.size-btn').forEach(b => {
                b.classList.remove('btn-dark');
                b.classList.add('btn-outline-dark');
            });
            el.classList.remove('btn-outline-dark');
            el.classList.add('btn-dark');
            selectedSizeId = el.dataset.sizeId;
            document.getElementById('sizeError').classList.add('d-none');
        }
    </script>
}