@using RetailSystem.UI.Models.Product;
@model AllProductViewModel

<div class="mb-4">
    <div class="d-flex gap-2 flex-wrap">
        <button onclick="filterAll(this)" class="cat-btn active">All</button>
        @foreach (var category in Model.Categories)
        {
            <button onclick="filterByCategory(this, '@category.Id')" class="cat-btn">
                @category.CategoryName
            </button>
        }
    </div>
</div>

<div id="product-list" class="product-grid">
    @foreach (var product in Model.Products)
    {
        <a href="@Url.Action("Detail", "Product", new { id = product.Id })"
           class="pcard-link">
            <div class="pcard">
                <div class="pcard-img-wrapper">
                    <img src="@product.ProductImages.FirstOrDefault(pi => pi.IsThumbnail).ImageUrl"
                         alt="@product.ProductName" />
                </div>
                <div class="pcard-body">
                    <h6 class="pcard-name">@product.ProductName</h6>
                    @if (!string.IsNullOrEmpty(product.Description))
                    {
                        <p class="pcard-desc">@product.Description</p>
                    }
                    <p class="pcard-price">@product.Price.ToString("C")</p>
                </div>
            </div>
        </a>
    }
</div>

<style>
    .cat-btn {
        border: 1px solid #dee2e6;
        background: #fff;
        color: #6c757d;
        border-radius: 999px;
        padding: 6px 18px;
        font-size: 13px;
        cursor: pointer;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
    }

        .cat-btn:hover {
            background: #f8f9fa;
            color: #212529;
        }

        .cat-btn.active {
            background: #212529;
            color: #fff;
            border-color: #212529;
        }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 2rem;
    }

    @@media (max-width: 768px) {
        .product-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .pcard-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .pcard {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #f0f0f0;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .pcard:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 28px rgba(0,0,0,0.10);
        }

    .pcard-img-wrapper img {
        width: 100%;
        aspect-ratio: 1/1;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
    }

    .pcard:hover .pcard-img-wrapper img {
        transform: scale(1.04);
    }

    .pcard-body {
        padding: 10px 14px 14px;
    }

    .pcard-name {
        font-size: 14px;
        font-weight: 600;
        margin: 0 0 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pcard-desc {
        font-size: 12px;
        color: #6c757d;
        margin: 0 0 8px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.5;
    }

    .pcard-price {
        font-size: 15px;
        font-weight: 700;
        color: #0d6efd;
        margin: 0;
    }
</style>

<script>
    const API_BASE = "https://localhost:44322";

    function setActiveBtn(btn) {
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }

    function renderProducts(data) {
        document.getElementById("product-list").innerHTML = data.map(p => {
            const img = (p.productImages && p.productImages.length > 0)
                ? p.productImages[0].imageUrl
                : '';

            const desc = p.description ? p.description : '';

            const price = p.price
    ? p.price.toLocaleString('en-US', { style: 'currency', currency: 'USD' })
    : '';

            return `
                <a href="/products/detail/${p.id}" class="pcard-link">
                    <div class="pcard">
                        <div class="pcard-img-wrapper">
                            <img src="${img}" alt="${p.productName}" />
                        </div>
                        <div class="pcard-body">
                            <h6 class="pcard-name">${p.productName}</h6>
                            <p class="pcard-desc">${desc}</p>
                            <p class="pcard-price">${price}</p>
                        </div>
                    </div>
                </a>
            `;
        }).join('');
    }

    async function filterByCategory(btn, categoryId) {
        setActiveBtn(btn);

        try {
            const res = await fetch(`${API_BASE}/products/filter?categoryId=${categoryId}`);

            if (!res.ok) {
                console.error("API error:", res.status);
                return;
            }

            const data = await res.json();
            renderProducts(data);
        } catch (err) {
            console.error("Fetch error:", err);
        }
    }

    async function filterAll(btn) {
        setActiveBtn(btn);

        try {
            const res = await fetch(`${API_BASE}/products`);

            if (!res.ok) {
                console.error("API error:", res.status);
                return;
            }

            const data = await res.json();
            renderProducts(data);
        } catch (err) {
            console.error("Fetch error:", err);
        }
    }
</script>