    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="9.0.13" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.3" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="9.0.15" />
